{
    "name": "cryptology_tbw",
    "version": "4.0.0.SPX-beta",
    "private": true,
    "description": "Cryptology True Block Weight SPX",
    "license": "CC BY-ND 4.0",
    "author": "Cryptology",
    "files": [
        "dist",
        "bin"
    ],
    "main": "dist/app",
    "types": "dist/app",
    "bin": {
        "tbw": "./bin/app"
    },
    "scripts": {
        "build": "yarn clean && yarn compile",
        "build:watch": "yarn clean && yarn compile -w",
        "clean": "del dist",
        "compile": "./node_modules/typescript/bin/tsc",
        "format": "yarn lint && yarn prettier",
        "lerna": "./node_modules/lerna/cli.js",
        "lint": "./node_modules/tslint/bin/tslint -c ./tslint.json 'src/**/*.ts' '__tests__/**/*.ts' --fix",
        "docs": "./node_modules/typedoc/bin/typedoc src --out docs",
        "prepublishOnly": "yarn build",
        "publish:alpha": "npm publish --tag alpha",
        "publish:beta": "npm publish --tag beta",
        "publish:latest": "npm publish --tag latest",
        "publish:rc": "npm publish --tag rc",
        "prettier": "prettier --write \"./*.{ts,js,json,md}\" \"./**/*.{ts,js,json,md}\"",
        "setup": "yarn && yarn clean && yarn build",
        "snyk": "./node_modules/.bin/snyk protect",
        "deps:missing": "node ./scripts/deps/missing.js",
        "pretest": "bash ./scripts/pre-test.sh",
        "test": "snyk test && cross-env CORE_ENV=test jest --runInBand --forceExit",
        "test:coverage": "cross-env CORE_ENV=test jest --coverage --coveragePathIgnorePatterns='/(defaults.ts|index.ts)$' --runInBand --forceExit",
        "test:debug": "cross-env CORE_ENV=test node --inspect-brk ../../node_modules/.bin/jest --runInBand",
        "test:watch": "cross-env CORE_ENV=test jest --runInBand --watch",
        "test:watch:all": "cross-env CORE_ENV=test jest --runInBand --watchAll",
        "updates": "ncu",
        "update": "ncu -u"
    },
    "jest": {
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!**/node_modules/**"
        ],
        "preset": "./jest-preset.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wownmedia/cryptology_tbw.git"
    },
    "bugs": {
        "url": "https://github.com/wownmedia/cryptology_tbw/issues"
    },
    "homepage": "https://github.com/wownmedia/cryptology_tbw#readme",
    "dependencies": {
        "@solar-network/crypto": "^3.3.0",
        "bytebuffer": "^5.0.1",
        "axios": "0.27.2",
        "bignumber.js": "^9.0.2",
        "chalk": "^5.0.1",
        "commander": "^9.3.0",
        "dotenv": "^16.0.1",
        "is-reachable": "^5.2.1",
        "@hapi/joi": "^17.1.1",
        "pg": "^8.7.3",
        "pg-query-stream": "^4.2.3",
        "pino": "^8.1.0",
        "pino-pretty": "^8.1.0",
        "prompt": "^1.3.0",
        "moment": "^2.29.4"
    },
    "devDependencies": {
        "@babel/core": "^7.18.6",
        "@babel/preset-env": "^7.18.6",
        "@sindresorhus/tsconfig": "^3.0.1",
        "@types/babel__core": "^7.1.19",
        "@types/body-parser": "^1.19.2",
        "@types/express": "^4.17.13",
        "@types/jest": "^28.1.4",
        "@types/joi": "^17.2.2",
        "@types/js-yaml": "^4.0.5",
        "@types/node": "^18.0.3",
        "@types/prettier": "^2.6.3",
        "@types/pino": "^7.0.4",
        "@types/prompts": "^2.4.0",
        "@types/request": "^2.48.8",
        "@types/request-promise": "^4.1.48",
        "@types/rimraf": "^3.0.2",
        "@types/uuid": "^8.3.4",
        "@types/webpack": "^5.28.0",
        "@types/webpack-merge": "^4.1.5",
        "@types/webpack-node-externals": "^2.5.3",
        "babel-loader": "^8.2.5",
        "body-parser": "^1.20.0",
        "codecov": "^3.8.2",
        "cross-env": "^7.0.3",
        "del-cli": "^4.0.1",
        "depcheck": "^1.4.3",
        "docdash": "^1.2.0",
        "express": "^4.18.1",
        "husky": "^8.0.1",
        "jest": "^28.1.2",
        "jest-extended": "^3.0.0",
        "js-yaml": "^4.1.0",
        "jsdoc": "^3.6.10",
        "lerna": "^5.1.8",
        "lint-staged": "^13.0.3",
        "npm-check-updates": "^15.2.6",
        "prettier": "^2.7.1",
        "prompts": "^2.4.2",
        "regenerator-runtime": "^0.13.9",
        "request": "^2.88.2",
        "request-promise": "^4.2.6",
        "rimraf": "^3.0.2",
        "snyk": "^1.971.0",
        "ts-jest": "^28.0.5",
        "tslint": "^6.1.3",
        "tslint-config-prettier": "^1.18.0",
        "typedoc": "^0.23.7",
        "typescript": "^4.7.4",
        "uuid": "^8.3.2",
        "webpack": "^5.73.0",
        "webpack-cli": "^4.10.0",
        "webpack-merge": "^5.8.0",
        "webpack-node-externals": "^3.0.0"
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix --debug"
        ]
    },
    "engines": {
        "node": ">=10.x"
    },
    "publishConfig": {
        "access": "public"
    },
    "prettier": {
        "tabWidth": 4,
        "trailingComma": "es5"
    }
}
